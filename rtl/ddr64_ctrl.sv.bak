module ddr64_ctrl (
  input logic clk,
  input logic rst_n,
  input logic crc_error_inject,
  benoc_if.slave benoc,
  ddr_if.ctrl    ddr
);

  import benoc_pkg::*;

  typedef enum logic [2:0] {
    S_IDLE,
    S_WRITE,
    S_READ_CMD,
    S_READ_WAIT,
    S_RESP
  } state_e;

  state_e state, next_state;

  benoc_pkt_t saved_pkt;
  logic [63:0] read_data_q;
  logic [7:0]  wr_crc_calc;

  // CRC generator for write data
  crc8 u_crc8_wr (
    .data_i(saved_pkt.data),
    .crc_o (wr_crc_calc)
  );

  always_ff @(posedge clk or negedge rst_n) begin
    if (!rst_n) begin
      state       <= S_IDLE;
      saved_pkt   <= '0;
      read_data_q <= '0;
    end
    else begin
      state <= next_state;

      if (state == S_IDLE && benoc.req_valid && benoc.req_ready) begin
        saved_pkt <= benoc.req_pkt;
      end

      if (state == S_READ_WAIT && ddr.rd_valid && ddr.rd_ready) begin
        read_data_q <= ddr.rd_data;
      end
    end
  end

  always_comb begin
    next_state = state;

    // BENoC defaults
    benoc.req_ready = 1'b0;
    benoc.rsp_valid = 1'b0;
    benoc.rsp_pkt   = '0;

    // DDR command defaults
    ddr.cmd_valid  = 1'b0;
    ddr.cmd_write  = 1'b0;
    ddr.cmd_addr   = '0;
    ddr.burst_len  = '0;

    // DDR write defaults
    ddr.wr_valid   = 1'b0;
    ddr.wr_data    = '0;
    ddr.wr_crc     = '0;

    // DDR read defaults
    ddr.rd_ready   = 1'b0;

    // Frequency ratio placeholder
    ddr.freq_ratio = 2'b00;

    case (state)

      S_IDLE: begin
        benoc.req_ready = 1'b1;

        if (benoc.req_valid) begin
          if (benoc.req_pkt.cmd == WRITE)
            next_state = S_WRITE;
          else
            next_state = S_READ_CMD;
        end
      end

      S_WRITE: begin
        ddr.cmd_valid = 1'b1;
        ddr.cmd_write = 1'b1;
        ddr.cmd_addr  = saved_pkt.addr;
        ddr.burst_len = saved_pkt.burst_len;

        ddr.wr_valid  = 1'b1;
        ddr.wr_data   = saved_pkt.data;
        ddr.wr_crc    = wr_crc_calc;

        if (ddr.cmd_ready && ddr.wr_ready)
          next_state = S_RESP;
      end

      S_READ_CMD: begin
        ddr.cmd_valid = 1'b1;
        ddr.cmd_write = 1'b0;
        ddr.cmd_addr  = saved_pkt.addr;
        ddr.burst_len = saved_pkt.burst_len;

        if (ddr.cmd_ready)
          next_state = S_READ_WAIT;
      end

      S_READ_WAIT: begin
        ddr.rd_ready = 1'b1;

        if (ddr.rd_valid)
          next_state = S_RESP;
      end

      S_RESP: begin
        benoc.rsp_valid      = 1'b1;
        benoc.rsp_pkt.src_id = saved_pkt.src_id;
        benoc.rsp_pkt.error  = 1'b0;
        benoc.rsp_pkt.rdata  = (saved_pkt.cmd == READ) ? read_data_q : 64'h0;

        if (benoc.rsp_ready)
          next_state = S_IDLE;
      end

      default: begin
        next_state = S_IDLE;
      end

    endcase
  end

endmodule