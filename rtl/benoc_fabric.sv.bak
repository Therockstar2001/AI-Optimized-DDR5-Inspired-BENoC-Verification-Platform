module benoc_fabric #(
  parameter int NUM_MASTERS = 4
)(
  input logic clk,
  input logic rst_n,

  benoc_if.slave  m_if [NUM_MASTERS],
  benoc_if.master ddr_if
);

  import benoc_pkg::*;

  logic [NUM_MASTERS-1:0] req_valid_vec;
  logic [1:0]             req_qos [NUM_MASTERS];

  logic [NUM_MASTERS-1:0] grant;
  logic [$clog2(NUM_MASTERS)-1:0] grant_id;
  logic grant_valid;

  integer i;

  // Collect request valid and QoS from all masters
  always_comb begin
    for (i = 0; i < NUM_MASTERS; i++) begin
      req_valid_vec[i] = m_if[i].req_valid;
      req_qos[i]       = m_if[i].req_pkt.qos;
    end
  end

  benoc_arbiter #(
    .NUM_MASTERS(NUM_MASTERS)
  ) u_arbiter (
    .clk         (clk),
    .rst_n       (rst_n),
    .req_valid   (req_valid_vec),
    .req_qos     (req_qos),
    .grant       (grant),
    .grant_id    (grant_id),
    .grant_valid (grant_valid)
  );

  // Request forwarding
  always_comb begin
    ddr_if.req_valid = 1'b0;
    ddr_if.req_pkt   = '0;

    for (i = 0; i < NUM_MASTERS; i++) begin
      m_if[i].req_ready = 1'b0;
    end

    if (grant_valid) begin
      ddr_if.req_valid = m_if[grant_id].req_valid;
      ddr_if.req_pkt   = m_if[grant_id].req_pkt;

      m_if[grant_id].req_ready = ddr_if.req_ready;
    end
  end

  // Response routing
  always_comb begin
    for (i = 0; i < NUM_MASTERS; i++) begin
      m_if[i].rsp_valid = 1'b0;
      m_if[i].rsp_pkt   = '0;
    end

    ddr_if.rsp_ready = 1'b0;

    if (ddr_if.rsp_valid) begin
      case (ddr_if.rsp_pkt.src_id)
        SRC_CPU: begin
          m_if[0].rsp_valid = ddr_if.rsp_valid;
          m_if[0].rsp_pkt   = ddr_if.rsp_pkt;
          ddr_if.rsp_ready  = m_if[0].rsp_ready;
        end

        SRC_AI: begin
          m_if[1].rsp_valid = ddr_if.rsp_valid;
          m_if[1].rsp_pkt   = ddr_if.rsp_pkt;
          ddr_if.rsp_ready  = m_if[1].rsp_ready;
        end

        SRC_DMA: begin
          m_if[2].rsp_valid = ddr_if.rsp_valid;
          m_if[2].rsp_pkt   = ddr_if.rsp_pkt;
          ddr_if.rsp_ready  = m_if[2].rsp_ready;
        end

        SRC_DBG: begin
          m_if[3].rsp_valid = ddr_if.rsp_valid;
          m_if[3].rsp_pkt   = ddr_if.rsp_pkt;
          ddr_if.rsp_ready  = m_if[3].rsp_ready;
        end

        default: begin
          ddr_if.rsp_ready = 1'b1;
        end
      endcase
    end
  end

endmodule